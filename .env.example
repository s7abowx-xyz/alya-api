# قاعدة البيانات (PostgreSQL - يفضل Neon أو أي مزود PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/alya_api?schema=public"

# منفذ الخادم
PORT=4000

# بيئة التشغيل
NODE_ENV=development

# أسرار JWT (استخدم قيم عشوائية طويلة وقوية في الإنتاج)
JWT_ACCESS_SECRET="change-this-access-secret"
JWT_REFRESH_SECRET="change-this-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# نطاق الواجهة الأمامية (لأغراض CORS)
CLIENT_ORIGIN="http://localhost:4000"
